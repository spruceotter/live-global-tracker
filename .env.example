# Cesium ion token (required for globe imagery + terrain)
# Get one free at https://ion.cesium.com/signup
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# OpenWeatherMap API key (optional, for weather overlay)
# Get one free at https://home.openweathermap.org/users/sign_up
VITE_OWM_API_KEY=your_openweathermap_key_here

# NASA FIRMS API key (optional, for wildfire hotspots)
# Get one free at https://firms.modaps.eosdis.nasa.gov/api/area/
VITE_FIRMS_API_KEY=your_nasa_firms_key_here
